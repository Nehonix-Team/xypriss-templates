{
  "package.json": {
    "&merge": {
      "scripts": {
        "xms:start": "xfpm run main/mode/xms/src/main.ts"
      }
    }
  },
  "xypriss.config.jsonc": {
    "&merge": {
      "$vars": {
        "servers": {
          "xms": {
            "id": "&(env).XMS_DOMAIN",
            "port": "&(env).XMS_PORT"
          }
        }
      }
    }
  }
}
